# DeepSeek
DEEPSEEK__API_KEY=sk-xxxxxxxx
DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
DEEPSEEK__MODEL=deepseek-chat

# Database (first database entry)
DATABASES__0__NAME=default_db
DATABASES__0__HOST=localhost
DATABASES__0__PORT=5432
DATABASES__0__DATABASE=postgres
DATABASES__0__USERNAME=readonly_user
DATABASES__0__PASSWORD=readonly_password
DATABASES__0__SSL_MODE=prefer
DATABASES__0__MIN_CONNECTIONS=1
DATABASES__0__MAX_CONNECTIONS=10
DATABASES__0__IS_DEFAULT=true

# Query / cache / server
QUERY__TIMEOUT_SECONDS=30
QUERY__MAX_ROWS=100
QUERY__MAX_ROWS_LIMIT=1000
SCHEMA_CACHE__TTL_MINUTES=60
SCHEMA_CACHE__AUTO_REFRESH=true
LOG_LEVEL=INFO
