# DeepSeek
DEEPSEEK__API_KEY=XXXX
DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
DEEPSEEK__MODEL=deepseek-chat

# Databases
# 0) blog_small (default)
DATABASES__0__NAME=blog_small
DATABASES__0__HOST=localhost
DATABASES__0__PORT=5432
DATABASES__0__DATABASE=blog_small
DATABASES__0__USERNAME=postgres
DATABASES__0__PASSWORD=leacock
DATABASES__0__SSL_MODE=prefer
DATABASES__0__MIN_CONNECTIONS=1
DATABASES__0__MAX_CONNECTIONS=10
DATABASES__0__IS_DEFAULT=true

# 1) ecommerce_medium
DATABASES__1__NAME=ecommerce_medium
DATABASES__1__HOST=localhost
DATABASES__1__PORT=5432
DATABASES__1__DATABASE=ecommerce_medium
DATABASES__1__USERNAME=postgres
DATABASES__1__PASSWORD=leacock
DATABASES__1__SSL_MODE=prefer
DATABASES__1__MIN_CONNECTIONS=1
DATABASES__1__MAX_CONNECTIONS=10
DATABASES__1__IS_DEFAULT=false

# 2) saas_crm_large
DATABASES__2__NAME=saas_crm_large
DATABASES__2__HOST=localhost
DATABASES__2__PORT=5432
DATABASES__2__DATABASE=saas_crm_large
DATABASES__2__USERNAME=postgres
DATABASES__2__PASSWORD=leacock
DATABASES__2__SSL_MODE=prefer
DATABASES__2__MIN_CONNECTIONS=1
DATABASES__2__MAX_CONNECTIONS=10
DATABASES__2__IS_DEFAULT=false

# Query / cache / server
QUERY__TIMEOUT_SECONDS=30
QUERY__MAX_ROWS=100
QUERY__MAX_ROWS_LIMIT=1000
QUERY__CONNECT_MAX_RETRIES=2
QUERY__CONNECT_RETRY_BASE_DELAY=0.5
QUERY__MAX_CONCURRENT_REQUESTS=0
QUERY__RATE_LIMIT_PER_MINUTE=0
QUERY__RATE_LIMIT_WINDOW_SECONDS=60
SCHEMA_CACHE__TTL_MINUTES=60
SCHEMA_CACHE__AUTO_REFRESH=true
SCHEMA_CACHE__PRELOAD_ON_STARTUP=false
SERVER__TRANSPORT=stdio
SERVER__HOST=127.0.0.1
SERVER__PORT=8000
SERVER__PATH=/mcp
SERVER__STATELESS_HTTP=false
SERVER__SHOW_BANNER=false
LOG_LEVEL=INFO
